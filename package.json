{
  "name": "uwo-shared-platform",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@8.0.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo prune --prod && rimraf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^1.9.0",
    "typescript": "^5.0.0"
  }
}

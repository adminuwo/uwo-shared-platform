{
  "$schema": "./manifest.schema.json",
  "version": 1,
  "products": ["aisa", "ai-mall", "aisa-connect", "ai-legal-professional", "ai-ads", "ai-cashflow"],
  "capabilities": ["identity", "organisation-and-tenant", "roles-and-entitlements", "dashboard-shell", "billing-and-credits", "ai-gateway-and-model-router", "storage", "notifications", "analytics", "audit", "security", "connectors", "knowledge-layer"],
  "components": [
    {
      "id": "ai-gateway",
      "type": "service",
      "path": "services/ai_gateway",
      "capabilities": ["identity", "organisation-and-tenant", "roles-and-entitlements", "billing-and-credits", "ai-gateway-and-model-router", "audit", "security", "connectors"],
      "endpoints": ["GET /healthz", "POST /v1/route", "POST /v1/execute"]
    },
    {
      "id": "shared-contracts",
      "type": "package",
      "path": "packages/contracts",
      "capabilities": ["identity", "organisation-and-tenant", "roles-and-entitlements", "billing-and-credits", "ai-gateway-and-model-router"],
      "endpoints": []
    },
    {
      "id": "platform-control-plane",
      "type": "service",
      "path": "services/platform_control_plane",
      "capabilities": ["identity", "organisation-and-tenant", "roles-and-entitlements", "audit", "security"],
      "endpoints": [
        "GET /healthz",
        "GET /v1/tenants",
        "POST /v1/tenants",
        "GET /v1/tenants/{tenant_id}",
        "POST /v1/tenants/{tenant_id}/status",
        "PUT /v1/tenants/{tenant_id}/memberships/{subject}",
        "POST /v1/tenants/{tenant_id}/memberships/{subject}/roles/{role_id}",
        "DELETE /v1/tenants/{tenant_id}/memberships/{subject}/roles/{role_id}",
        "GET /v1/tenants/{tenant_id}/permissions/{subject}",
        "GET /v1/tenants/{tenant_id}/entitlements",
        "POST /v1/tenants/{tenant_id}/entitlements/products/{product}",
        "DELETE /v1/tenants/{tenant_id}/entitlements/products/{product}",
        "POST /v1/tenants/{tenant_id}/entitlements/models/{model}",
        "DELETE /v1/tenants/{tenant_id}/entitlements/models/{model}",
        "GET /v1/tenants/{tenant_id}/policy-version"
      ]
    },
    {
      "id": "platform-billing",
      "type": "service",
      "path": "services/platform_billing",
      "capabilities": ["identity", "organisation-and-tenant", "roles-and-entitlements", "billing-and-credits", "audit", "security"],
      "endpoints": [
        "GET /healthz",
        "POST /v1/billing/accounts",
        "GET /v1/billing/accounts/{tenant_id}",
        "POST /v1/billing/accounts/{tenant_id}/status",
        "GET /v1/billing/accounts/{tenant_id}/balance",
        "POST /v1/billing/accounts/{tenant_id}/credits/grants",
        "POST /v1/billing/accounts/{tenant_id}/credits/adjustments",
        "POST /v1/billing/accounts/{tenant_id}/credits/refunds",
        "POST /v1/billing/reservations",
        "POST /v1/billing/reservations/{reservation_id}/capture",
        "POST /v1/billing/reservations/{reservation_id}/release",
        "GET /v1/billing/accounts/{tenant_id}/usage/{usage_event_id}",
        "GET /v1/billing/accounts/{tenant_id}/ledger",
        "GET /v1/billing/accounts/{tenant_id}/rate-card"
      ]
    }
  ]
}

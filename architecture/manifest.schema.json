{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "products", "capabilities", "components"],
  "properties": {
    "version": {"const": 1},
    "products": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "capabilities", "endpoints"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["service", "package", "application", "infrastructure", "tooling"]},
          "path": {"type": "string"},
          "capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "endpoints": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
